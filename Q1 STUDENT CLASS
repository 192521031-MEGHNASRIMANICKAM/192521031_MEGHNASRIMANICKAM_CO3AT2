#include<iostream>
#include<cstring>
using namespace std;
class Student
{
    char *name;
    int marks;
    public:
    Student(char n[],int m)
    {
        name=new char[strlen(n)+1];
        strcpy(name,n);
        marks=m;
    }
    Student(const Student &s)
    {
        name=new char[strlen(s.name)+1];
        strcpy(name,s.name);
        marks=s.marks;
    }
    void setName(char n[])
    {
        strcpy(name,n);
    }
    void display()
    {
        cout<<"Name:"<<name<<endl;
        cout<<"Marks:"<<marks<<endl;
    }
    ~Student()
    {
        delete[] name;
    }
};
int main()
{
    Student s1((char*)"Meghna",95);
    Student s2=s1;
    s2.setName((char*)"Priya");
    cout<<"Student 1"<<endl;
    s1.display();
    cout<<"Student 2"<<endl;
    s2.display();
    return 0;
}
